/// Kullanıcının kendi oluşturduğu hatırlatıcı; belirlenen zamanda otomatik
/// olarak hem uygulama içi bildirim listesinde (getTaskReminderHub) hem de
/// push bildirimi (cron/reminders) olarak tetiklenir.
model Reminder {
  id            String    @id @default(cuid())
  ownerId       String
  institutionId String?
  studentId     String?
  title         String
  note          String?
  remindAt      DateTime
  isCompleted   Boolean   @default(false)
  notifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  student       Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([ownerId, remindAt])
  @@index([remindAt, notifiedAt, isCompleted])
}

/// Bir bildirim/hatırlatıcı öğesinin (TeacherReminderRecord.id) bir kullanıcı
/// tarafından okundu/kapatıldı olarak işaretlenmesi. Hem türetilmiş
/// hatırlatıcılar (ram-*, bep-*, ...) hem de Reminder (reminder-*) kayıtları
/// için tek, kalıcı okundu mekanizması sağlar.
model NotificationDismissal {
  id          String   @id @default(cuid())
  userId      String
  reminderId  String
  dismissedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reminderId])
  @@index([userId])
}

/// Kalıcı uygulama içi bildirim kaydı. Push bildirimi (Firebase, uygulama dışı)
/// gönderilen HER olay (yeni mesaj, destek talebi yanıtı, hatırlatıcı, ...) için
/// src/lib/notifications.ts#notifyUsers tarafından aynı anda oluşturulur —
/// böylece "uygulama dışı bildirim geldi ama uygulama içinde yok" sorunu
/// yaşanmaz; iki kanal her zaman tek bir kaynaktan, birlikte tetiklenir.
model AppNotification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

