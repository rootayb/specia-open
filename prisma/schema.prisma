// Cihaz eşleştirme: kullanıcının daha önce doğruladığı (güvenilen) cihazlar.
// Bir cihaz güvenilirse o cihazdan girişte 2FA kodu istenmez; tanınmayan
// cihazdan girişte e-posta kodu devreye girer. deviceId ham olarak değil
// SHA-256 özetiyle saklanır.
model MobileTrustedDevice {
  id           String   @id @default(cuid())
  userId       String
  deviceIdHash String
  deviceName   String?
  platform     String?  @default("ios")
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceIdHash])
  @@index([userId])
}

