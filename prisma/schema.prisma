model SupportTicket {
  id              String               @id @default(cuid())
  userId          String?
  name            String?
  email           String
  subject         String
  message         String?
  status          String  @default("open")
  source          String               @default("web") // "web" | "email"
  priority        String               @default("normal") // "low" | "normal" | "high"
  externalEmailId String?
  closedAt        DateTime?
  closedById      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  closedBy        User?                @relation("SupportTicketClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  replies         SupportTicketReply[]

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

