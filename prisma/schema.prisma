model BepGoalProgressEntry {
  id                String             @id @default(cuid())
  documentId        String
  planRowId         String
  studentId         String
  institutionId     String?
  createdById       String
  status            String @default("in_progress")
  phase             String      @default("acquisition")
  progressPercent   Int                @default(0)
  note              String?
  nextStep          String?
  measuredAt        DateTime
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  dailyQuickEntryId String?            @unique
  document          BepDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  planRow           BepPlanRow         @relation(fields: [planRowId], references: [id], onDelete: Cascade)
  student           Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  institution       Institution?       @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  createdBy         User               @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([documentId, measuredAt])
  @@index([planRowId, measuredAt])
  @@index([planRowId, phase])
  @@index([studentId, measuredAt])
  @@index([institutionId, measuredAt])
  @@index([createdById, measuredAt])
}

