generator client {
  provider = "prisma-client-js"
  // İndirilebilir paketin Windows/macOS/Linux üzerinde çalışabilmesi için
  // tüm platformların sorgu motorları birlikte üretilir.
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Özel eğitimde öğrenme aşamaları: edinim, akıcılık, kalıcılık, genelleme.

// Bir seansın gerçekleşme sonucu: 5 durumlu devam takibi.

// MEM'e (ilçe Milli Eğitim Müdürlüğü) gönderilen hak ediş talebinin idari onay süreci.
// Yukarıdaki EntitlementClaimStatus'tan bağımsızdır: o mali mutabakatı, bu ise MEM
// nezdindeki gönderim/onay/red akışının kağıt izini tutar.

model User {
  id                               String                           @id @default(cuid())
  email                            String                           @unique
  appleSubject                     String?                          @unique
  googleSubject                    String?                          @unique
  passwordHash                     String
  name                             String
  role                             String                         @default("teacher")
  branch                           String?
  employmentType                   String?
  allowedModules                   Json          @default("[]")
  isActive                         Boolean                          @default(true)
  suspendedUntil                   DateTime?
  twoFactorEnabled                 Boolean                          @default(false)
  institutionId                    String?
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  institution                      Institution?                     @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  students                         Student[]
  documents                        BepDocument[]
  aiLogs                           AiSuggestionLog[]
  auditLogs                        AuditLog[]
  passwordResetTokens              PasswordResetToken[]
  createdInviteCodes               InviteCode[]                     @relation("InviteCodesCreatedBy")
  usedInviteCodes                  InviteCode[]                     @relation("InviteCodesUsedBy")
  parentStudentLinks               ParentStudentLink[]              @relation("ParentStudentLinkUser")
  updatedInstitutionSettings       InstitutionSettings[]            @relation("InstitutionSettingsUpdatedBy")
  studentFiles                     StudentFile[]
  studentFileFolders               StudentFileFolder[]
  updatedSessions                  InstitutionSession[]             @relation("SessionUpdatedBy")
  deletedSessions                  InstitutionSession[]             @relation("SessionDeletedBy")
  assignedSessions                 InstitutionSession[]             @relation("SessionTeacher")
  createdSessions                  InstitutionSession[]             @relation("SessionCreatedBy")
  createdCalendarEvents            CalendarEvent[]                  @relation("CalendarEventCreatedBy")
  assignedCalendarEvents           CalendarEvent[]                  @relation("CalendarEventAssignedTo")
  sentParentMessages               ParentMessage[]                  @relation("ParentMessageSender")
  receivedParentMessages           ParentMessage[]                  @relation("ParentMessageRecipient")
  createdMeetings                  CoordinationMeeting[]            @relation("CoordinationMeetingCreatedBy")
  createdZumreMeetings             ZumreMeetingDocument[]           @relation("ZumreMeetingCreatedBy")
  createdInvoices                  InstitutionInvoice[]             @relation("InstitutionInvoiceCreatedBy")
  createdFinancialTariffs          FinancialTariff[]                @relation("FinancialTariffCreatedBy")
  createdEntitlementClaims         EntitlementClaim[]               @relation("EntitlementClaimCreatedBy")
  createdMebImports                MebAttendanceImport[]            @relation("MebAttendanceImportCreatedBy")
  createdInvoicePayments           InstitutionInvoicePayment[]      @relation("InstitutionInvoicePaymentCreatedBy")
  staffExpenses                    StaffExpense[]                   @relation("StaffExpenseStaffUser")
  createdStaffExpenses             StaffExpense[]                   @relation("StaffExpenseCreatedBy")
  createdGeneralExpenses           GeneralExpense[]                 @relation("GeneralExpenseCreatedBy")
  reviewedInstitutionApplications  InstitutionApplication[]         @relation("InstitutionApplicationReviewedBy")
  createdPlatformAnnouncements     PlatformAnnouncement[]           @relation("PlatformAnnouncementCreatedBy")
  updatedPlatformAnnouncements     PlatformAnnouncement[]           @relation("PlatformAnnouncementUpdatedBy")
  createdStatusIncidents           PlatformStatusIncident[]         @relation("PlatformStatusIncidentCreatedBy")
  updatedStatusIncidents           PlatformStatusIncident[]         @relation("PlatformStatusIncidentUpdatedBy")
  createdStatusIncidentUpdates     PlatformStatusIncidentUpdate[]   @relation("PlatformStatusIncidentUpdateCreatedBy")
  courseEvaluationDocuments        CourseEvaluationDocument[]       @relation("CourseEvaluationOwner")
  evaluationDocuments              EvaluationDocument[]             @relation("EvaluationOwner")
  bepGoalProgressEntries           BepGoalProgressEntry[]
  specialEducationReinforcers      SpecialEducationReinforcer[]     @relation("SpecialEducationReinforcerCreatedBy")
  sensoryRegulationMenuItems       SensoryRegulationMenuItem[]      @relation("SensoryRegulationMenuItemCreatedBy")
  specialEducationDailyDataEntries SpecialEducationDailyDataEntry[] @relation("SpecialEducationDailyDataEntryCreatedBy")
  dailyQuickEntries                DailyQuickEntry[]                @relation("DailyQuickEntryCreatedBy")
  productFeedbackEntries           ProductFeedback[]
  createdInstitutionRamReports     InstitutionRamTracking[]         @relation("InstitutionRamTrackingCreatedBy")
  createdInstitutionTransportPlans InstitutionTransportPlan[]       @relation("InstitutionTransportPlanCreatedBy")
  createdInstitutionArchiveRecords InstitutionArchiveRecord[]       @relation("InstitutionArchiveRecordCreatedBy")
  createdFamilyEducationPlans      FamilyEducationPlan[]            @relation("FamilyEducationPlanCreatedBy")
  createdFamilyEducationNotes      FamilyEducationNote[]            @relation("FamilyEducationNoteCreatedBy")
  familyEducationResponses         FamilyEducationResponse[]        @relation("FamilyEducationResponseCreatedBy")
  personalNotes                    PersonalNote[]
  personalNoteFolders              PersonalNoteFolder[]
  createdBepTransferInvites        BepTransferInvite[]              @relation("BepTransferInviteCreatedBy")
  acceptedBepTransferInvites       BepTransferInvite[]              @relation("BepTransferInviteAcceptedBy")
  createdStudentTransferInvites    StudentTransferInvite[]          @relation("StudentTransferInviteCreatedBy")
  acceptedStudentTransferInvites   StudentTransferInvite[]          @relation("StudentTransferInviteAcceptedBy")
  mobileRefreshTokens              MobileRefreshToken[]
  mobileTrustedDevices             MobileTrustedDevice[]
  authIdentities                   AuthIdentity[]
  supportTickets                   SupportTicket[]
  closedSupportTickets             SupportTicket[]                  @relation("SupportTicketClosedBy")
  supportTicketReplies             SupportTicketReply[]
  blogPosts                        BlogPost[]                       @relation("BlogPostAuthor")
  skillTemplates                   SkillTemplate[]                  @relation("SkillTemplateAuthor")
  abcLogs                          AbcLog[]                         @relation("AbcLogTeacher")
  maintenanceWindows               MaintenanceWindow[]              @relation("MaintenanceWindowCreatedBy")
  updatedLegalDocuments            LegalDocumentContent[]           @relation("LegalDocumentUpdatedBy")
  webSessions                      WebSession[]
  trustedWebDevices                TrustedWebDevice[]
  reminders                        Reminder[]
  notificationDismissals           NotificationDismissal[]
  appNotifications                 AppNotification[]

  @@index([institutionId])
}

model WebSession {
  id         String   @id
  userId     String
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  lastActive DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrustedWebDevice {
  id           String   @id @default(cuid())
  userId       String
  deviceIdHash String
  deviceLabel  String?
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceIdHash])
  @@index([userId])
}

model Institution {
  id                     String                      @id @default(cuid())
  name                   String
  slug                   String                      @unique
  type                   String             @default("rehabilitation_center")
  isActive               Boolean                     @default(true)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  users                  User[]
  students               Student[]
  documents              BepDocument[]
  inviteCodes            InviteCode[]
  settings               InstitutionSettings[]
  studentFiles           StudentFile[]
  studentFileFolders     StudentFileFolder[]
  rooms                  SessionRoom[]
  sessionTimeSlots       SessionTimeSlot[]
  sessions               InstitutionSession[]
  calendarEvents         CalendarEvent[]
  parentMessages         ParentMessage[]
  meetings               CoordinationMeeting[]
  zumreMeetings          ZumreMeetingDocument[]
  invoices               InstitutionInvoice[]
  financialTariffs       FinancialTariff[]
  entitlementClaims      EntitlementClaim[]
  staffExpenses          StaffExpense[]
  generalExpenses        GeneralExpense[]
  mebAttendanceImports   MebAttendanceImport[]
  invoicePayments        InstitutionInvoicePayment[]
  courseEvaluations      CourseEvaluationDocument[]
  evaluationDocuments    EvaluationDocument[]
  goalProgressEntries    BepGoalProgressEntry[]
  dailyQuickEntries      DailyQuickEntry[]
  productFeedbackEntries ProductFeedback[]
  ramReports             InstitutionRamTracking[]
  transportPlans         InstitutionTransportPlan[]
  archiveRecords         InstitutionArchiveRecord[]
  familyEducationPlans   FamilyEducationPlan[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RegistrationVerification {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  inviteCode   String?
  codeHash     String
  expiresAt    DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expiresAt])
}

model TwoFactorCode {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model InstitutionSettings {
  id                       String       @id @default(cuid())
  institutionId            String?
  schoolName               String?
  district                 String?
  city                     String?
  address                  String?
  phone                    String?
  email                    String?
  principalName            String?
  principalTitle           String?
  defaultManagerName       String?
  defaultManagerTitle      String?
  legalName                String?
  taxOffice                String?
  taxNumber                String?
  mersisNumber             String?
  iban                     String?
  invoicePrefix            String?
  publicAuthorityName      String?
  publicAuthorityTitle     String?
  publicAuthorityTaxOffice String?
  publicAuthorityTaxNumber String?
  publicAuthorityAddress   String?
  notes                    String?
  logoData                 Bytes?
  logoMimeType             String?
  logoFileName             String?
  updatedById              String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  institution              Institution? @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  updatedBy                User?        @relation("InstitutionSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([institutionId])
  @@index([institutionId])
  @@index([updatedById])
}

model Student {
  id                               String                           @id @default(cuid())
  ownerId                          String
  institutionId                    String?
  enrollmentType                   String            @default("regular")
  isActive                         Boolean                          @default(true)
  enrollmentStartDate              DateTime?
  enrollmentEndDate                DateTime?
  archivedAt                       DateTime?
  firstName                        String
  lastName                         String
  kademe                           String?
  classroom                        String?
  schoolNumber                     String?
  schoolName                       String?
  birthDate                        DateTime?
  district                         String?
  placementDecision                String?
  diagnosis                        String?
  previousSupport                  String?
  currentSupport                   String?
  supportMaterials                 String?
  healthNotes                      String?
  educationAdjustments             String?
  bepStartDate                     DateTime?
  bepEndDate                       DateTime?
  motherName                       String?
  motherPhone                      String?
  fatherName                       String?
  fatherPhone                      String?
  guardianName                     String?
  guardianPhone                    String?
  motherHomeAddress                String?
  fatherHomeAddress                String?
  guardianHomeAddress              String?
  homeAddress                      String?
  motherWorkAddress                String?
  fatherWorkAddress                String?
  guardianWorkAddress              String?
  workAddress                      String?
  developmentHistory               String?
  strengths                        String?
  improvementAreas                 String?
  behaviorNotes                    String?
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  owner                            User                             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  institution                      Institution?                     @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  documents                        BepDocument[]
  parentStudentLinks               ParentStudentLink[]
  inviteCodes                      InviteCode[]
  studentFiles                     StudentFile[]
  sessions                         InstitutionSession[]
  calendarEvents                   CalendarEvent[]
  parentMessages                   ParentMessage[]
  meetings                         CoordinationMeeting[]
  courseEvaluations                CourseEvaluationDocument[]
  evaluationDocuments              EvaluationDocument[]
  goalProgressEntries              BepGoalProgressEntry[]
  specialEducationReinforcers      SpecialEducationReinforcer[]
  sensoryRegulationMenuItems       SensoryRegulationMenuItem[]
  specialEducationDailyDataEntries SpecialEducationDailyDataEntry[]
  dailyQuickEntries                DailyQuickEntry[]
  ramReports                       InstitutionRamTracking[]
  entitlementClaimLines            EntitlementClaimLine[]
  behaviors                        StudentBehavior[]
  abcLogs                          AbcLog[]
  mebAttendanceRows                MebAttendanceImportRow[]
  transportPlans                   InstitutionTransportPlan[]
  familyEducationPlans             FamilyEducationPlan[]
  studentTransferInvites           StudentTransferInvite[]
  reminders                        Reminder[]

  @@index([ownerId])
  @@index([institutionId])
  @@index([institutionId, isActive])
  @@index([institutionId, enrollmentType])
}

model BepDocument {
  id                               String                           @id @default(cuid())
  studentId                        String
  ownerId                          String
  institutionId                    String?
  title                            String
  status                           String                        @default("draft")
  approvalStatus                   String                @default("approved")
  submittedAt                      DateTime?
  approvedAt                       DateTime?
  approvedById                     String?
  approvedByName                   String?
  rejectedAt                       DateTime?
  rejectedById                     String?
  rejectedByName                   String?
  rejectionReason                  String?
  startDate                        DateTime?
  endDate                          DateTime?
  learningEnvironmentText          String?
  physicalEnvironmentText          String?
  socialInteractionText            String?
  digitalSupportsText              String?
  familyFrequency                  String?
  familyMethod                     String?
  familyTrainingRequired           Boolean                          @default(false)
  familyTrainingMethod             String?
  nextMeetingDate                  DateTime?
  generalEvaluation                String?
  otherDecisionOne                 String?
  otherDecisionTwo                 String?
  otherDecisionThree               String?
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  owner                            User                             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  student                          Student                          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  institution                      Institution?                     @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  performanceEntries               PerformanceEntry[]
  planRows                         BepPlanRow[]
  supportServiceEntries            BepSupportServiceEntry[]
  decisionEntries                  DecisionEntry[]
  committeeMembers                 CommitteeMember[]
  subjectTeachers                  SubjectTeacher[]
  aiLogs                           AiSuggestionLog[]
  goalProgressEntries              BepGoalProgressEntry[]
  specialEducationDailyDataEntries SpecialEducationDailyDataEntry[]
  dailyQuickEntries                DailyQuickEntry[]
  productFeedbackEntries           ProductFeedback[]
  transferInvites                  BepTransferInvite[]

  @@index([studentId])
  @@index([ownerId])
  @@index([institutionId])
  @@index([approvalStatus])
}

model BepTransferInvite {
  id                     String            @id @default(cuid())
  documentId             String
  fromUserId             String
  acceptedById           String?
  tokenHash              String            @unique
  status                 String @default("pending")
  previousOwnerId        String
  previousStudentOwnerId String
  acceptedAt             DateTime?
  undoUntil              DateTime?
  expiresAt              DateTime
  canceledAt             DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  document               BepDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fromUser               User              @relation("BepTransferInviteCreatedBy", fields: [fromUserId], references: [id], onDelete: Cascade)
  acceptedBy             User?             @relation("BepTransferInviteAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([fromUserId])
  @@index([acceptedById])
  @@index([status])
  @@index([expiresAt])
}

model StudentTransferInvite {
  id                    String            @id @default(cuid())
  studentId             String
  fromUserId            String
  acceptedById          String?
  tokenHash             String            @unique
  status                String @default("pending")
  previousOwnerId       String
  previousInstitutionId String?
  acceptedAt            DateTime?
  undoUntil             DateTime?
  expiresAt             DateTime
  canceledAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  student               Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromUser              User              @relation("StudentTransferInviteCreatedBy", fields: [fromUserId], references: [id], onDelete: Cascade)
  acceptedBy            User?             @relation("StudentTransferInviteAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([fromUserId])
  @@index([acceptedById])
  @@index([status])
  @@index([expiresAt])
}

model ProductFeedback {
  id            String                @id @default(cuid())
  userId        String
  institutionId String?
  documentId    String?
  source        String @default("bep_completed")
  value         String
  reason        String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution   Institution?          @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  document      BepDocument?          @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([userId, documentId, source])
  @@index([userId, createdAt])
  @@index([institutionId, createdAt])
  @@index([documentId, createdAt])
  @@index([value, createdAt])
}

model BepSupportServiceEntry {
  id                String      @id @default(cuid())
  documentId        String
  sortOrder         Int
  serviceType       String
  courseName        String?
  weeklyDuration    String?
  responsiblePeople String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  document          BepDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model CourseEvaluationDocument {
  id             String                @id @default(cuid())
  studentId      String
  ownerId        String
  institutionId  String?
  title          String
  courseId       String
  courseName     String
  evaluatorName  String?
  evaluationDate DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  student        Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  owner          User                  @relation("CourseEvaluationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  institution    Institution?          @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  rows           CourseEvaluationRow[]

  @@index([studentId])
  @@index([ownerId])
  @@index([institutionId])
  @@index([courseId])
}

model CourseEvaluationRow {
  id               String                   @id @default(cuid())
  documentId       String
  sortOrder        Int
  courseId         String?
  courseName       String?
  unitName         String
  learningArea     String
  learningOutcome  String
  processComponent String?
  result           String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  document         CourseEvaluationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model EvaluationDocument {
  id             String       @id @default(cuid())
  studentId      String
  ownerId        String
  institutionId  String?
  title          String
  type           String
  kazanim        String?
  evaluationType String?
  evaluationDate DateTime?
  evaluatorName  String?
  data           Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  owner          User         @relation("EvaluationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  institution    Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([ownerId])
  @@index([institutionId])
  @@index([type])
}

model StudentFile {
  id            String              @id @default(cuid())
  studentId     String?
  institutionId String?
  createdById   String
  folderId      String?
  title         String
  category      String @default("other")
  fileName      String?
  fileUrl       String?
  fileData      Bytes?
  mimeType      String?
  fileSize      Int?
  notes         String?
  documentDate  DateTime?
  expiresAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  student       Student?            @relation(fields: [studentId], references: [id], onDelete: SetNull)
  institution   Institution?        @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  createdBy     User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  folder        StudentFileFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([institutionId])
  @@index([createdById])
  @@index([folderId])
  @@index([category])
}

model StudentFileFolder {
  id            String        @id @default(cuid())
  institutionId String?
  createdById   String
  name          String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  institution   Institution?  @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  createdBy     User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  files         StudentFile[]

  @@index([institutionId])
  @@index([createdById])
  @@index([name])
}

model SessionRoom {
  id            String               @id @default(cuid())
  institutionId String
  name          String
  color         String?
  isActive      Boolean              @default(true)
  archivedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  institution   Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  sessions      InstitutionSession[]

  @@unique([institutionId, name])
  @@index([institutionId])
  @@index([institutionId, isActive])
}

model SessionTimeSlot {
  id              String               @id @default(cuid())
  institutionId   String
  name            String
  startTime       String
  durationMinutes Int                  @default(40)
  sortOrder       Int                  @default(0)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  institution     Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  sessions        InstitutionSession[]

  @@unique([institutionId, startTime])
  @@index([institutionId, sortOrder])
  @@index([institutionId, isActive])
}

model InstitutionSession {
  id                              String                   @id @default(cuid())
  institutionId                   String
  studentId                       String
  teacherId                       String?
  roomId                          String?
  timeSlotId                      String?
  createdById                     String
  updatedById                     String?
  deletedById                     String?
  sessionDate                     DateTime
  startTime                       String
  durationMinutes                 Int                      @default(40)
  sessionType                     String              @default("individual")
  status                          String            @default("planned")
  notes                           String?
  attendanceVerified              Boolean                  @default(false)
  attendanceVerificationReference String?
  attendanceVerifiedAt            DateTime?
  attendanceOutcome               String?
  makeupReference                 String?
  makeupEducationType             String?
  deletedAt                       DateTime?
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt
  institution                     Institution              @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student                         Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher                         User?                    @relation("SessionTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  room                            SessionRoom?             @relation(fields: [roomId], references: [id], onDelete: SetNull)
  timeSlot                        SessionTimeSlot?         @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)
  createdBy                       User                     @relation("SessionCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy                       User?                    @relation("SessionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedBy                       User?                    @relation("SessionDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  mebAttendanceRows               MebAttendanceImportRow[]

  @@index([institutionId, sessionDate])
  @@index([institutionId, sessionDate, deletedAt])
  @@index([studentId, sessionDate])
  @@index([teacherId, sessionDate])
  @@index([roomId, sessionDate])
  @@index([timeSlotId])
  @@index([deletedAt])
}

model CalendarEvent {
  id             String             @id @default(cuid())
  title          String
  description    String?
  scope          String @default("personal")
  institutionId  String?
  ownerId        String
  assignedUserId String?
  studentId      String?
  startAt        DateTime
  endAt          DateTime
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  institution    Institution?       @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  owner          User               @relation("CalendarEventCreatedBy", fields: [ownerId], references: [id], onDelete: Cascade)
  assignedUser   User?              @relation("CalendarEventAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)
  student        Student?           @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([institutionId, startAt])
  @@index([assignedUserId, startAt])
  @@index([studentId, startAt])
  @@index([ownerId, startAt])
}

model InviteCode {
  id            String      @id @default(cuid())
  institutionId String
  createdById   String
  usedById      String?
  code          String      @unique
  role          String
  email         String?
  studentId     String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())
