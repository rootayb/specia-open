  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  abcLogs      AbcLog[]

  @@index([studentId])
}

model AbcLog {
  id                 String           @id @default(cuid())
  studentId          String
  behaviorId         String
  timestamp          DateTime         @default(now())
  durationSeconds    Int              @default(0)
  frequency          Int              @default(1)
  lessonName         String?
  subTopic           String?
  teacherId          String
  classSize          Int?

  // A-C etiketleri
  antecedentTag      String?
  antecedentDisplay  String?
  consequenceTag     String?
  consequenceDisplay String?
  teacherNotes       String?

  // Analiz Sonuçları
  inferredFunction   String?
  confidenceScore    Float?

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  behavior           StudentBehavior  @relation(fields: [behaviorId], references: [id], onDelete: Cascade)
  teacher            User             @relation("AbcLogTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([behaviorId])
  @@index([teacherId])
}

