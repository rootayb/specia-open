# Specia Local ortam değişkenleri.
# Bu dosyayı elle kopyalamanıza gerek yok: `npm run setup:local` komutu
# .env dosyası yoksa rastgele anahtarlarla otomatik oluşturur.

# SQLite veritabanı dosyası (prisma/ klasörüne göre göreli yol)
DATABASE_URL="file:./dev.db"

NEXTAUTH_URL="http://localhost:3000"
# Uzun rastgele bir değer — üretmek için:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=""
DOCUMENT_LINK_SECRET=""

# PII şifreleme — 64 hex karakter (32 byte) anahtar.
# DİKKAT: Bu anahtar kaybolursa veritabanındaki şifreli kişisel veriler
# kalıcı olarak okunamaz hale gelir. .env dosyanızı yedekleyin!
DB_ENCRYPTION_KEY=""

# Next.js telemetri gönderimini kapat (tamamen çevrimdışı çalışma)
NEXT_TELEMETRY_DISABLED=1
